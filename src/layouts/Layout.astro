---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Tingkatkan views & otomatisasi konten TikTok-mu. Super cepat, tanpa harus manual." } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts Plus Jakarta Sans -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,700&display=swap" rel="stylesheet">

		<title>{title}</title>

		<style is:inline>

/* ─── GOLDEN RATIO TYPE SCALE (base 16px × φ=1.618) ─── */
:root {
  --phi: 1.618;
  --t0: 0.618rem;   /* 9.9px  — micro label  */
  --t1: 1rem;       /* 16px   — body         */
  --t2: 1.618rem;   /* 25.9px — lead text    */
  --t3: 2.618rem;   /* 41.9px — section head */
  --t4: 4.236rem;   /* 67.8px — display      */
  --t5: 6.854rem;   /* 109.7px— hero         */

  /* FIBONACCI SPACING (8px base) */
  --s1: 8px;
  --s2: 13px;
  --s3: 21px;
  --s4: 34px;
  --s5: 55px;
  --s6: 89px;
  --s7: 144px;

  /* COLORS */
  --bg:   #050a0f;
  --bg2:  #080f18;
  --bg3:  #0c1825;
  --bg4:  #0f2030;

  --green:    #dc2626;
  --green-lt: #ef4444;
  --green-xl: #f87171;
  --green-glow: rgba(220,38,38,.5);
  --green-dim:  rgba(220,38,38,.1);
  --green-dim2: rgba(220,38,38,.06);

  --white: #ffffff;
  --t-hi:  rgba(255,255,255,.95);
  --t-md:  rgba(255,255,255,.55);
  --t-lo:  rgba(255,255,255,.28);
  --line:  rgba(255,255,255,.07);
  --line2: rgba(220,38,38,.2);

  --maxw: 1140px;
  --r: 50px; /* rounded from tweaks */
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0 }
html { scroll-behavior:smooth }
body {
  font-family:'Plus Jakarta Sans',system-ui,sans-serif;
  background:var(--bg);
  color:var(--t-hi);
  line-height:1.6;
  overflow-x:hidden;
}
h1,h2,h3,h4 { line-height:1.05; letter-spacing:-0.03em; color:var(--white) }
a { color:inherit; text-decoration:none }
img { max-width:100%; display:block }

.wrap { width:100%; max-width:var(--maxw); margin:0 auto; padding:0 var(--s4) }

/* ─── TOP GLOW LINE ─── */
.topline {
  height:1px;
  background:linear-gradient(90deg,transparent 0%,var(--green) 30%,var(--green-lt) 50%,var(--green) 70%,transparent 100%);
  box-shadow:0 0 20px var(--green-glow);
}

/* ─── ANNOUNCE ─── */
.ann {
  background:var(--bg2);
  border-bottom:1px solid var(--line);
  padding:var(--s2) 0;
  text-align:center;
  font-size:var(--t0);
  font-weight:600;
  color:var(--t-md);
  position:sticky;
  top:0;
  z-index:300;
  letter-spacing:.06em;
  text-transform:uppercase;
}
.ann strong { color:var(--green-lt) }
.ann-code {
  background:var(--green-dim);
  border:1px dashed rgba(52,211,153,.3);
  padding:1px 8px;
  border-radius:4px;
  font-family:monospace;
  font-weight:800;
  color:var(--green-lt);
  letter-spacing:.05em;
}
.pulse-dot {
  display:inline-block;
  width:6px; height:6px;
  background:var(--green);
  border-radius:50%;
  margin-right:var(--s2);
  vertical-align:middle;
  animation:pulse-dot 1.4s infinite;
  box-shadow:0 0 8px var(--green-glow);
}

/* ─── NAV ─── */
.nav {
  background:rgba(5,10,15,.92);
  backdrop-filter:blur(24px);
  border-bottom:1px solid var(--line);
  padding:var(--s3) 0;
  position:sticky;
  top:35px;
  z-index:200;
}
.nav-i { display:flex; align-items:center; justify-content:space-between }
.logo { font-weight:800; font-size:var(--t1); letter-spacing:-.025em }
.logo em { color:var(--green-lt); font-style:normal }

/* ─── BUTTONS ─── */
.btn {
  display:inline-flex; align-items:center; justify-content:center; gap:var(--s2);
  font-family:'Plus Jakarta Sans',sans-serif;
  font-weight:700;
  padding:12px 28px;
  border-radius:var(--r);
  border:none; cursor:pointer;
  transition:all .2s;
  text-decoration:none;
  letter-spacing:.01em;
  font-size:var(--t1);
}
.btn-green {
  background:var(--green);
  color:white;
  box-shadow:0 0 24px var(--green-glow);
}
.btn-green:hover {
  background:var(--green-lt);
  box-shadow:0 0 40px var(--green-glow);
  transform:translateY(-2px);
}
.btn-ghost {
  background:transparent;
  color:var(--t-md);
  border:1px solid var(--line);
}
.btn-ghost:hover { border-color:var(--green); color:var(--green-lt) }
.btn-lg { font-size:var(--t2); padding:var(--s4) var(--s6) }
.btn-xl {
  font-size:var(--t2);
  padding:var(--s4) var(--s6);
  width:100%;
  animation:cta-beat 2.5s infinite;
}

/* ─── SECTION LABEL ─── */
.label {
  display:inline-flex;
  align-items:center;
  gap:var(--s2);
  font-size:var(--t0);
  font-weight:700;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--green-lt);
  margin-bottom:var(--s3);
}
.label-dot {
  width:6px; height:6px;
  background:var(--green);
  border-radius:50%;
  box-shadow:0 0 8px var(--green-glow);
  animation:pulse-dot 1.4s infinite;
}

/* ─── HERO ─── */
.hero {
  min-height:100vh;
  display:flex;
  align-items:center;
  padding:var(--s7) 0 var(--s6);
  position:relative;
  overflow:hidden;
}
.hero::before {
  content:'';
  position:absolute; inset:0;
  background:
    radial-gradient(ellipse 70% 70% at 75% 50%, rgba(220,38,38,.1) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(220,38,38,.05) 0%, transparent 55%);
  pointer-events:none;
}
.hero::after {
  content:'';
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(220,38,38,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(220,38,38,.04) 1px, transparent 1px);
  background-size:64px 64px;
  pointer-events:none;
  opacity:.5;
}
.hero-g {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:var(--s6);
  align-items:center;
  position:relative;
  z-index:1;
}
.hero-badge {
  display:inline-flex;
  align-items:center;
  gap:var(--s2);
  background:var(--green-dim);
  border:1px solid var(--line2);
  color:var(--green-lt);
  padding:var(--s2) var(--s3);
  border-radius:4px;
  font-size:var(--t0);
  font-weight:700;
  letter-spacing:.12em;
  text-transform:uppercase;
  margin-bottom:var(--s4);
}
.hero h1 {
  font-size:clamp(var(--t4), 6.5vw, var(--t5));
  font-weight:800;
  margin-bottom:var(--s4);
  line-height:1.0;
  letter-spacing:-.035em;
}
.hero h1 em {
  font-style:normal;
  background:linear-gradient(135deg, var(--green-xl), var(--green));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  display:block;
}
.hero-lead {
  font-size:var(--t2);
  color:var(--t-md);
  margin-bottom:var(--s5);
  max-width:420px;
  line-height:1.55;
  font-weight:400;
}
.hero-cta-row { display:flex; flex-direction:column; gap:var(--s3) }
.hero-note {
  font-size:var(--t0);
  color:var(--t-lo);
  display:flex; align-items:center; gap:var(--s2);
  letter-spacing:.04em;
}
.live-row {
  display:flex; align-items:center; gap:var(--s2);
  font-size:var(--t0);
  color:var(--t-lo);
  margin-top:var(--s2);
}
.live-dot {
  width:7px; height:7px;
  background:#ef4444;
  border-radius:50%;
  animation:pulse-dot 1.2s infinite;
  box-shadow:0 0 8px #ef4444;
  flex-shrink:0;
}

/* Mockup */
.hero-visual { position:relative }
.mockup-outer {
  position:relative;
  border-radius:20px;
}
.mockup-glow {
  position:absolute;
  inset:-40px;
  background:radial-gradient(ellipse 70% 60% at 50% 50%, rgba(220,38,38,.22) 0%, transparent 70%);
  pointer-events:none;
  border-radius:50%;
}
.mockup {
  width:100%;
  aspect-ratio:16/10;
  background:var(--bg3);
  border-radius:20px;
  border:1px solid rgba(220,38,38,.2);
  position:relative;
  overflow:hidden;
  box-shadow:
    0 0 0 1px rgba(220,38,38,.1),
    0 0 60px rgba(220,38,38,.15),
    0 40px 80px rgba(0,0,0,.6);
}
.mockup::before {
  content:'';
  position:absolute; inset:0;
  background:repeating-linear-gradient(
    45deg,transparent,transparent 20px,
    rgba(220,38,38,.025) 20px,rgba(220,38,38,.025) 40px
  );
}
.mockup img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; border-radius:20px }
.mock-lbl {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  font-size:var(--t0);
  color:rgba(255,255,255,.18);
  text-align:center;
  line-height:2;
  z-index:1;
}
.status-badge {
  position:absolute;
  bottom:-16px; right:-16px;
  background:var(--bg2);
  border:1px solid rgba(220,38,38,.35);
  border-radius:12px;
  padding:var(--s2) var(--s3);
  font-size:var(--t0);
  font-weight:700;
  color:var(--white);
  display:flex; align-items:center; gap:var(--s2);
  box-shadow:0 0 20px rgba(220,38,38,.25), 0 8px 24px rgba(0,0,0,.5);
  z-index:5;
  animation:float 5s ease-in-out infinite;
  white-space:nowrap;
}

/* ─── STATS BAR ─── */
.stats-bar {
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
  padding:var(--s5) 0;
  background:var(--bg2);
}
.stats-inner {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  text-align:center;
  position:relative;
}
.stats-inner::before, .stats-inner::after {
  content:'';
  position:absolute;
  top:10%; bottom:10%;
  width:1px;
  background:var(--line);
}
.stats-inner::before { left:33.33% }
.stats-inner::after  { left:66.66% }
.stat-item {}
.stat-n {
  font-size:var(--t4);
  font-weight:800;
  letter-spacing:-.04em;
  line-height:1;
  background:linear-gradient(135deg, white, var(--green-xl));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  margin-bottom:var(--s2);
  display:block;
}
.stat-l {
  font-size:var(--t0);
  font-weight:600;
  color:var(--t-lo);
  text-transform:uppercase;
  letter-spacing:.1em;
}

/* ─── MACHINE REVEAL ─── */
.machine-reveal {
  padding:var(--s7) 0;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.machine-reveal::before {
  content:'MACHINE';
  position:absolute;
  top:50%; left:50%;
  transform:translate(-50%,-50%);
  font-size:22vw;
  font-weight:800;
  color:rgba(255,255,255,.015);
  letter-spacing:-.04em;
  white-space:nowrap;
  pointer-events:none;
  line-height:1;
}
.reveal-inner { max-width:760px; margin:0 auto }
.reveal-inner h2 {
  font-size:clamp(var(--t3), 4.5vw, var(--t4));
  font-weight:800;
  margin-bottom:var(--s4);
  line-height:1.05;
}
.reveal-inner h2 em {
  font-style:normal;
  background:linear-gradient(135deg, var(--green-xl), var(--green));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}
.reveal-inner p {
  font-size:var(--t2);
  color:var(--t-md);
  line-height:1.65;
  max-width:580px;
  margin:0 auto var(--s6);
  font-weight:400;
}
.reveal-mockup {
  max-width:900px;
  margin:0 auto;
  position:relative;
}
.reveal-mockup-img {
  width:100%;
  aspect-ratio:16/9;
  background:var(--bg3);
  border-radius:16px;
  border:1px solid rgba(220,38,38,.18);
  position:relative;
  overflow:hidden;
  box-shadow:0 0 80px rgba(220,38,38,.15), 0 0 0 1px rgba(220,38,38,.08), 0 60px 120px rgba(0,0,0,.7);
}
.reveal-mockup-img::before {
  content:'';
  position:absolute; inset:0;
  background:repeating-linear-gradient(45deg,transparent,transparent 16px,rgba(220,38,38,.02) 16px,rgba(220,38,38,.02) 32px);
}
.reveal-mockup-img img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; border-radius:16px }
.reveal-mockup-lbl {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center;
  font-size:var(--t0); color:rgba(255,255,255,.18);
  z-index:1; text-align:center; line-height:2;
}
.reveal-glow {
  position:absolute; inset:-60px;
  background:radial-gradient(ellipse 60% 50% at 50% 50%, rgba(220,38,38,.18) 0%, transparent 65%);
  pointer-events:none;
}

/* ─── FEATURE ROWS ─── */
.feat-rows { padding:var(--s6) 0 }
.feat-row {
  padding:var(--s7) 0;
  border-top:1px solid var(--line);
  position:relative;
  overflow:hidden;
}
.feat-row:last-child { border-bottom:1px solid var(--line) }
.feat-row-inner {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:var(--s7);
  align-items:center;
}
.feat-row.alt .feat-row-inner { direction:rtl }
.feat-row.alt .feat-row-inner > * { direction:ltr }
.feat-num {
  font-size:clamp(6rem, 14vw, var(--t5));
  font-weight:800;
  letter-spacing:-.05em;
  line-height:.9;
  color:rgba(255,255,255,.04);
  margin-bottom:var(--s4);
  display:block;
}
.feat-row-text {}
.feat-title {
  font-size:clamp(var(--t3), 3.5vw, var(--t4));
  font-weight:800;
  margin-bottom:var(--s3);
  line-height:1.05;
}
.feat-title em {
  font-style:normal;
  background:linear-gradient(135deg, var(--green-xl), var(--green));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}
.feat-desc {
  font-size:var(--t2);
  color:var(--t-md);
  line-height:1.65;
  max-width:440px;
  margin-bottom:var(--s4);
  font-weight:400;
}
.feat-tag {
  display:inline-flex;
  align-items:center;
  gap:var(--s2);
  background:var(--green-dim);
  border:1px solid var(--line2);
  color:var(--green-lt);
  padding:var(--s2) var(--s3);
  border-radius:6px;
  font-size:var(--t0);
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
}
.feat-visual {
  display:flex;
  align-items:center;
  justify-content:center;
}
.feat-stat-box {
  background:var(--bg2);
  border:1px solid var(--line2);
  border-radius:20px;
  padding:var(--s6) var(--s6);
  text-align:center;
  box-shadow:0 0 40px rgba(220,38,38,.08);
  width:100%;
  max-width:320px;
  position:relative;
  overflow:hidden;
}
.feat-stat-box::before {
  content:'';
  position:absolute;
  top:0; left:0; right:0;
  height:2px;
  background:linear-gradient(90deg, transparent, var(--green), transparent);
}
.feat-big-n {
  font-size:clamp(var(--t4), 7vw, var(--t5));
  font-weight:800;
  letter-spacing:-.04em;
  line-height:1;
  background:linear-gradient(135deg, white, var(--green-lt));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  display:block;
  margin-bottom:var(--s2);
}
.feat-big-label {
  font-size:var(--t0);
  color:var(--t-lo);
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.1em;
}
.feat-row-bg {
  position:absolute; inset:0;
  pointer-events:none;
  opacity:.4;
}

/* ─── HOW IT WORKS ─── */
.hiw {
  padding:var(--s7) 0;
  background:var(--bg2);
  border-top:1px solid var(--line);
}
.hiw-hd { text-align:center; margin-bottom:var(--s6) }
.hiw-hd h2 { font-size:clamp(var(--t3), 4vw, var(--t4)); margin-bottom:var(--s3) }
.hiw-hd h2 em { font-style:normal; background:linear-gradient(135deg, var(--green-xl), var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
.hiw-hd p { font-size:var(--t2); color:var(--t-md); max-width:520px; margin:0 auto; font-weight:400 }
.timeline {
  max-width:760px;
  margin:0 auto;
  position:relative;
}
.timeline::before {
  content:'';
  position:absolute;
  left:28px; top:0; bottom:0;
  width:1px;
  background:linear-gradient(180deg, var(--green) 0%, rgba(220,38,38,.2) 100%);
}
.tl-step {
  display:flex;
  gap:var(--s5);
  align-items:flex-start;
  padding:0 0 var(--s6) 0;
  position:relative;
}
.tl-step:last-child { padding-bottom:0 }
.tl-num {
  width:56px; height:56px;
  background:var(--bg);
  border:1px solid var(--green);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:var(--t1);
  font-weight:800;
  color:var(--green-lt);
  flex-shrink:0;
  position:relative;
  z-index:1;
  box-shadow:0 0 20px rgba(220,38,38,.3);
}
.tl-content { padding-top:var(--s2) }
.tl-content h3 {
  font-size:var(--t2);
  font-weight:800;
  color:white;
  margin-bottom:var(--s2);
}
.tl-content p { font-size:var(--t1); color:var(--t-md); line-height:1.65 }
.hiw-cta { text-align:center; margin-top:var(--s6) }

/* ─── COMPARISON ─── */
.comp {
  padding:var(--s7) 0;
  border-top:1px solid var(--line);
}
.comp-hd { text-align:center; margin-bottom:var(--s6) }
.comp-hd h2 { font-size:clamp(var(--t3), 4vw, var(--t4)); margin-bottom:var(--s3) }
.comp-hd h2 em { font-style:normal; background:linear-gradient(135deg, var(--green-xl), var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
.comp-hd p { font-size:var(--t1); color:var(--t-md); max-width:500px; margin:0 auto }
.comp-g {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:var(--s3);
  max-width:860px;
  margin:0 auto;
}
.comp-box {
  border-radius:16px;
  overflow:hidden;
  background:var(--bg2);
  border:1px solid var(--line);
}
.comp-box.good {
  border-color:rgba(220,38,38,.35);
  box-shadow:0 0 30px rgba(220,38,38,.1);
  position:relative;
}
.comp-top {
  padding:var(--s3) var(--s4);
  border-bottom:1px solid var(--line);
  background:rgba(255,255,255,.02);
}
.comp-box.good .comp-top {
  background:var(--green-dim2);
  border-color:rgba(220,38,38,.15);
}
.comp-title { font-size:var(--t1); font-weight:800; color:var(--t-md) }
.comp-box.good .comp-title { color:var(--green-lt) }
.comp-body { padding:var(--s4) }
.ci {
  display:flex; gap:var(--s3); align-items:flex-start;
  margin-bottom:var(--s3);
  font-size:var(--t1); line-height:1.55; color:var(--t-md);
}
.ci:last-child { margin-bottom:0 }
.ci-mark {
  width:20px; height:20px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; margin-top:1px;
  font-size:.7rem; font-weight:800;
}
.ci-mark.bad { background:rgba(239,68,68,.12); color:#f87171 }
.ci-mark.good { background:var(--green-dim); color:var(--green-lt) }
.comp-verdict {
  margin:var(--s3) var(--s4) var(--s4);
  padding:var(--s2) var(--s3);
  border-radius:8px;
  font-size:var(--t0);
  font-weight:700;
  letter-spacing:.04em;
}
.comp-verdict.bad { background:rgba(239,68,68,.08); color:#f87171; border:1px solid rgba(239,68,68,.18) }
.comp-verdict.good { background:var(--green-dim); color:var(--green-lt); border:1px solid var(--line2) }
.best-tag {
  position:absolute; top:0; right:0;
  background:var(--green);
  color:white;
  font-size:var(--t0);
  font-weight:800;
  letter-spacing:.1em;
  text-transform:uppercase;
  padding:var(--s1) var(--s3);
  border-bottom-left-radius:10px;
}

/* ─── MODULES ─── */
.mods {
  padding:var(--s7) 0;
  background:var(--bg2);
  border-top:1px solid var(--line);
}
.mods-hd { text-align:center; margin-bottom:var(--s6) }
.mods-hd h2 { font-size:clamp(var(--t3), 4vw, var(--t4)); margin-bottom:var(--s3) }
.mods-hd h2 em { font-style:normal; background:linear-gradient(135deg, var(--green-xl), var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
.mods-hd p { font-size:var(--t1); color:var(--t-md); max-width:500px; margin:0 auto }
.mods-g {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:var(--s3);
  max-width:960px;
  margin:0 auto;
}
.mc {
  background:var(--bg);
  border:1px solid var(--line);
  border-radius:16px;
  overflow:hidden;
  transition:border-color .25s, transform .25s, box-shadow .25s;
}
.mc:hover {
  border-color:rgba(220,38,38,.4);
  transform:translateY(-4px);
  box-shadow:0 0 30px rgba(220,38,38,.1);
}
.mc-head {
  background:linear-gradient(135deg, var(--bg3), var(--bg4));
  padding:var(--s4);
  border-bottom:1px solid var(--line);
  position:relative;
  overflow:hidden;
}
.mc-head::after {
  content:'';
  position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg, transparent, var(--green), transparent);
}
.mc-num {
  font-size:var(--t0);
  font-weight:700;
  letter-spacing:.16em;
  text-transform:uppercase;
  color:var(--green-lt);
  margin-bottom:var(--s2);
}
.mc-head h3 { font-size:var(--t1); color:white; font-weight:700; margin-bottom:4px }
.mc-sub { font-size:var(--t0); color:var(--t-lo) }
.mc-body { padding:var(--s4) }
.lesson {
  display:flex; gap:var(--s2); align-items:flex-start;
  padding:var(--s2) 0;
  border-bottom:1px solid rgba(255,255,255,.04);
  font-size:var(--t1); color:var(--t-md); line-height:1.5;
}
.lesson:last-child { border-bottom:none; padding-bottom:0 }
.lesson:first-child { padding-top:0 }
.play-ico {
  width:16px; height:16px;
  border-radius:50%;
  background:var(--green);
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; margin-top:2px;
}
.play-tri { width:0; height:0; border-top:4px solid transparent; border-bottom:4px solid transparent; border-left:6px solid white; margin-left:1px }
.bonus-strip {
  max-width:960px;
  margin:var(--s4) auto 0;
  background:var(--green-dim);
  border:1px solid var(--line2);
  border-radius:12px;
  padding:var(--s4);
  display:flex; align-items:center; gap:var(--s4);
  font-size:var(--t1); color:var(--t-md);
}
.bonus-ico {
  width:40px; height:40px;
  background:rgba(220,38,38,.2);
  border:1px solid rgba(220,38,38,.3);
  border-radius:8px;
  display:flex; align-items:center; justify-content:center;
  font-size:var(--t2); flex-shrink:0; color:var(--green-lt);
}

/* ─── CLOSING (URGENCY + CHECKOUT) ─── */
.closing {
  padding:var(--s7) 0;
  border-top:1px solid var(--line);
  position:relative;
  overflow:hidden;
}
.closing::before {
  content:'';
  position:absolute; inset:0;
  background:radial-gradient(ellipse 70% 60% at 50% 100%, rgba(220,38,38,.1) 0%, transparent 60%);
  pointer-events:none;
}
.closing-hd {
  text-align:center;
  max-width:820px;
  margin:0 auto var(--s6);
  position:relative;
  z-index:1;
}
.closing-hd h2 {
  font-size:clamp(var(--t3), 5vw, var(--t4));
  font-weight:800;
  margin-bottom:var(--s4);
  line-height:1.05;
}
.closing-hd h2 em { font-style:normal; background:linear-gradient(135deg, var(--green-xl), var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
.closing-hd p { font-size:var(--t2); color:var(--t-md); max-width:620px; margin:0 auto var(--s5); font-weight:400 }
.urgency-stats {
  display:flex;
  gap:var(--s3);
  justify-content:center;
  align-items:center;
  margin-bottom:var(--s5);
  flex-wrap:wrap;
}
.us {
  text-align:center;
  padding:var(--s4) var(--s5);
  background:var(--bg2);
  border:1px solid var(--line);
  border-radius:var(--r);
}
.us-n {
  font-size:clamp(var(--t3),5vw,var(--t4));
  font-weight:800;
  letter-spacing:-.04em;
  line-height:1;
  margin-bottom:var(--s2);
  display:block;
}
.us-n.dim { color:rgba(255,255,255,.25) }
.us-n.bright { background:linear-gradient(135deg,var(--green-xl),var(--green)); -webkit-background-clip:text; -webkit-text-fill-color:transparent }
.us-l { font-size:var(--t0); color:var(--t-lo); font-weight:600; text-transform:uppercase; letter-spacing:.09em }
.vs-sep { font-size:var(--t2); font-weight:800; color:rgba(255,255,255,.18) }

.warn-box {
  max-width:640px;
  margin:0 auto var(--s5);
  background:var(--green-dim);
  border:1px solid var(--line2);
  padding:var(--s3) var(--s4);
  border-radius:10px;
  font-size:var(--t1);
  color:var(--t-md);
  text-align:center;
  line-height:1.6;
}
.warn-box strong { color:white }

/* Pricing Card */
.pricing-wrap {
  max-width:620px;
  margin:0 auto;
  position:relative;
  z-index:1;
}
.pricing-card {
  background:var(--bg2);
  border:1px solid rgba(220,38,38,.3);
  border-radius:24px;
  overflow:hidden;
  box-shadow:0 0 60px rgba(220,38,38,.15), 0 40px 80px rgba(0,0,0,.4);
}
.pricing-top {
  background:linear-gradient(135deg, var(--bg3), var(--bg4));
  padding:var(--s4) var(--s5);
  display:flex; align-items:center; justify-content:space-between;
  border-bottom:1px solid rgba(220,38,38,.15);
}
.pricing-top::after {
  content:'';
  position:absolute; left:0; right:0;
  height:1px;
  background:linear-gradient(90deg, transparent, var(--green), transparent);
  top:0;
}
.pricing-name { font-size:var(--t1); font-weight:800; color:white }
.promo-badge {
  background:var(--green);
  color:white;
  font-size:var(--t0);
  font-weight:800;
  padding:var(--s1) var(--s3);
  border-radius:6px;
  letter-spacing:.06em;
  text-transform:uppercase;
  box-shadow:0 0 14px rgba(220,38,38,.4);
}
.pricing-body { padding:var(--s5) var(--s5); text-align:center }
.price-note {
  background:rgba(255,255,255,.04);
  border:1px solid var(--line);
  border-radius:10px;
  padding:var(--s2) var(--s4);
  font-size:var(--t0);
  color:var(--t-lo);
  font-weight:600;
  margin-bottom:var(--s4);
}
.price-row {
  display:flex; align-items:center; justify-content:center;
  gap:var(--s4); margin-bottom:var(--s3); flex-wrap:wrap;
}
.p-old { text-decoration:line-through; color:rgba(255,255,255,.2); font-size:var(--t2); font-weight:600 }
.p-arrow { color:rgba(255,255,255,.15); font-size:var(--t2) }
.p-new {
  font-size:clamp(var(--t3),6vw,var(--t4));
  font-weight:800;
  letter-spacing:-.04em;
  background:linear-gradient(135deg, white, var(--green-xl));
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  line-height:1;
}
.savings-tag {
  display:inline-flex; align-items:center; gap:var(--s2);
  background:var(--green-dim);
  border:1px solid var(--line2);
  color:var(--green-lt);
  font-size:var(--t0); font-weight:700;
  padding:var(--s1) var(--s3);
  border-radius:6px;
  margin-bottom:var(--s4);
}
.coupon-box {
  background:rgba(220,38,38,.05);
  border:1px dashed rgba(220,38,38,.3);
  border-radius:10px;
  padding:var(--s2) var(--s4);
  font-size:var(--t0);
  color:var(--t-md);
  margin-bottom:var(--s4);
  display:flex; align-items:center; justify-content:center; gap:var(--s2);
  flex-wrap:wrap;
}
.coupon-code {
  background:var(--green-dim);
  border:1px solid rgba(220,38,38,.3);
  padding:2px 10px;
  border-radius:4px;
  font-family:monospace;
  font-weight:800;
  color:var(--green-lt);
  letter-spacing:.05em;
}
.cta-btn {
  width:100%;
  padding:var(--s4) var(--s5);
  font-size:var(--t2);
  font-weight:800;
  border-radius:var(--r);
  background:var(--green);
  color:white;
  border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center; gap:var(--s2);
  font-family:'Plus Jakarta Sans',sans-serif;
  text-decoration:none;
  transition:all .2s;
  animation:cta-beat 2.5s infinite;
  box-shadow:0 0 40px rgba(220,38,38,.4);
  letter-spacing:.01em;
}
.cta-btn:hover { background:var(--green-lt); box-shadow:0 0 60px rgba(220,38,38,.6); transform:translateY(-2px) }
.guarantee-row {
  display:flex; flex-wrap:wrap; justify-content:center;
  gap:var(--s3); margin-top:var(--s4);
}
.guar {
  display:flex; align-items:center; gap:var(--s2);
  font-size:var(--t0); color:var(--t-lo); font-weight:600;
}
.guar-dot {
  width:14px; height:14px;
  background:var(--green-dim);
  border:1px solid var(--green);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  color:var(--green-lt); font-size:.6rem; font-weight:800;
}
.security-note {
  margin-top:var(--s3);
  font-size:var(--t0);
  color:var(--t-lo);
  text-align:center;
}

/* ─── FOOTER ─── */
.footer {
  background:var(--bg);
  border-top:1px solid var(--line);
  padding:var(--s5) 0;
}
.footer-i {
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:var(--s3);
}
.foot-logo { font-weight:800; font-size:var(--t1); color:rgba(255,255,255,.6) }
.foot-logo em { color:var(--green-lt); font-style:normal }
.footer p { font-size:var(--t0); color:var(--t-lo); max-width:480px; line-height:1.6 }

/* ─── TWEAKS PANEL ─── */
.tweaks {
  position:fixed; bottom:var(--s4); right:var(--s4);
  background:var(--bg3);
  border:1px solid rgba(220,38,38,.3);
  border-radius:16px;
  padding:var(--s4);
  box-shadow:0 0 40px rgba(220,38,38,.2), 0 20px 60px rgba(0,0,0,.6);
  z-index:9999;
  display:none;
  width:240px;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.tweaks.open { display:block }
.tw-t { font-size:var(--t1); font-weight:800; color:white; margin-bottom:var(--s3); border-bottom:1px solid var(--line); padding-bottom:var(--s2) }
.tw-row { margin-bottom:var(--s3) }
.tw-lbl { display:block; font-size:var(--t0); font-weight:700; color:var(--t-lo); text-transform:uppercase; letter-spacing:.1em; margin-bottom:var(--s2) }
.sw-row { display:flex; gap:var(--s2) }
.swatch { width:26px; height:26px; border-radius:50%; border:2px solid transparent; cursor:pointer; transition:transform .15s }
.swatch:hover { transform:scale(1.12) }
.swatch.active { border-color:white }
.tog-row { display:flex; justify-content:space-between; align-items:center; font-size:var(--t0); color:var(--t-md) }
.tog { width:36px; height:20px; background:rgba(255,255,255,.1); border-radius:10px; position:relative; cursor:pointer; transition:background .2s; border:none; flex-shrink:0 }
.tog.on { background:var(--green) }
.tth { position:absolute; top:2px; left:2px; width:16px; height:16px; background:white; border-radius:50%; transition:left .2s; box-shadow:0 1px 4px rgba(0,0,0,.4) }
.tog.on .tth { left:18px }

/* ─── SCROLL FADE ─── */
.fade { opacity:0; transform:translateY(28px); transition:opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1) }
.fade.vis { opacity:1; transform:none }
.fade-l { opacity:0; transform:translateX(-28px); transition:opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1) }
.fade-l.vis { opacity:1; transform:none }
.fade-r { opacity:0; transform:translateX(28px); transition:opacity .65s cubic-bezier(.16,1,.3,1), transform .65s cubic-bezier(.16,1,.3,1) }
.fade-r.vis { opacity:1; transform:none }

/* ─── KEYFRAMES ─── */
@keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.8)} }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
@keyframes cta-beat { 0%,100%{box-shadow:0 0 30px rgba(220,38,38,.4)} 55%{box-shadow:0 0 60px rgba(220,38,38,.7)} }

/* ─── RESPONSIVE ─── */
@media(max-width:1024px) {
  .feat-row-inner { grid-template-columns:1fr; gap:var(--s5) }
  .feat-row.alt .feat-row-inner { direction:ltr }
  .feat-visual { justify-content:flex-start }
  .feat-stat-box { max-width:100%; margin:0 auto; }
}
@media(max-width:768px) {
  :root {
    --t1: 0.95rem;
    --t2: 1.25rem;
    --t3: 1.8rem;
    --t4: 2.4rem;
    --t5: 3.2rem;
    --s4: 24px;
    --s5: 32px;
    --s6: 48px;
    --s7: 64px;
  }
  .nav { top:32px }
  .hero { padding:var(--s6) 0; min-height:auto }
  .hero-g { grid-template-columns:1fr; gap:var(--s5); text-align:center }
  .hero-lead { margin: 0 auto var(--s5); }
  .hero-cta-row { align-items:center; }
  .hero-visual { order:-1 }
  .stats-inner { grid-template-columns:1fr 1fr 1fr }
  .stats-inner::before, .stats-inner::after { display:none }
  .stat-n { font-size:var(--t3) }
  .comp-g { grid-template-columns:1fr }
  .mods-g { grid-template-columns:1fr }
  .footer-i { flex-direction:column; text-align:center }
  .urgency-stats { flex-direction:column }
  .us { width:100% }
  .pricing-top { flex-direction:column; gap:var(--s2); text-align:center }
  .feat-row { padding:var(--s6) 0 }
  .feat-title { font-size:var(--t3) }
}
@media(max-width:480px) {
  :root { 
    --t1: 0.9rem;
    --t2: 1.1rem;
    --t3: 1.5rem;
    --t4: 2rem;
    --t5: 2.5rem;
  }
  .ann { font-size:.64rem }
  .btn-lg { font-size:var(--t1); padding:var(--s3) var(--s4) }
  .stats-inner { grid-template-columns:1fr; gap:var(--s3); }
}

