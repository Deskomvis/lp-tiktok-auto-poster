<script>
// Live counter
const lc = document.getElementById('live-ct');
if(lc){lc.textContent=Math.floor(Math.random()*18)+22;setInterval(()=>{lc.textContent=Math.floor(Math.random()*18)+22},9000)}

// Scroll animations
const io = new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');io.unobserve(e.target)}});
},{threshold:.08});
document.querySelectorAll('.fade,.fade-l,.fade-r').forEach(el=>io.observe(el));

// Tweaks
window.addEventListener('message',e=>{
  if(e.data?.type==='__activate_edit_mode') document.getElementById('tweaks').classList.add('open');
  if(e.data?.type==='__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('open');
});
window.parent.postMessage({type:'__edit_mode_available'},'*');

const TWEAK_DEFAULTS=/*EDITMODE-BEGIN*/{
  "accent": "#dc2626",
  "accentLt": "#f87171",
  "accentXl": "#fca5a5",
  "rounded": true,
  "grid": true
}/*EDITMODE-END*/;
let T={...TWEAK_DEFAULTS};

function applyT(t){
  const r=document.documentElement;
  r.style.setProperty('--green',t.accent);
  r.style.setProperty('--green-lt',t.accentLt);
  r.style.setProperty('--green-xl',t.accentXl);
  r.style.setProperty('--green-glow',t.accent+'80');
  r.style.setProperty('--green-dim','rgba(0,0,0,0) linear-gradient('+t.accent+'1a,'+t.accent+'1a)');
  // simpler approach: just set alpha versions
  const hex=t.accent;
  r.style.setProperty('--green-dim',hex+'1a');
  r.style.setProperty('--green-dim2',hex+'0f');
  r.style.setProperty('--line2',hex+'33');
  r.style.setProperty('--r', t.rounded ? '50px' : '8px');
  document.getElementById('r-lbl').textContent=t.rounded?'Rounded':'Sharp';
  document.getElementById('r-tog').classList.toggle('on',t.rounded);
  // grid
  document.querySelector('.hero').style.setProperty('--grid-opacity',t.grid?'.5':'0');
  if(t.grid) document.querySelector('.hero::after');
  document.querySelectorAll('.hero').forEach(el=>{el.style.opacity=t.grid?'1':'0'});
  document.getElementById('g-lbl').textContent=t.grid?'Aktif':'Mati';
  document.getElementById('g-tog').classList.toggle('on',t.grid);
  // swatches
  document.querySelectorAll('.swatch').forEach(s=>s.classList.toggle('active',s.dataset.c===t.accent));
}
applyT(T);

function setC(el){
  T.accent=el.dataset.c; T.accentLt=el.dataset.lt; T.accentXl=el.dataset.xl;
  applyT(T);
  window.parent.postMessage({type:'__edit_mode_set_keys',edits:{accent:T.accent,accentLt:T.accentLt,accentXl:T.accentXl}},'*');
}
function toggleR(el){
  T.rounded=!T.rounded; applyT(T);
  window.parent.postMessage({type:'__edit_mode_set_keys',edits:{rounded:T.rounded}},'*');
}
function toggleGrid(el){
  T.grid=!T.grid; applyT(T);
  window.parent.postMessage({type:'__edit_mode_set_keys',edits:{grid:T.grid}},'*');
}
</script>

