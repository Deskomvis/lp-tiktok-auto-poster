---
// Features.astro
const features = [
  {
    icon: "🛒",
    title: "Auto Keranjang Kuning",
    desc: "Setiap video yang diupload langsung tertautkan produk TikTok Shop kamu secara otomatis. Tidak perlu lagi pilih satu per satu.",
    highlight: "Hemat 3–5 jam/hari"
  },
  {
    icon: "🤖",
    title: "Upload 30 Akun Sekaligus",
    desc: "Kelola puluhan akun TikTok dari satu dashboard. Software otomatis rotasi akun, upload, dan set deskripsi tanpa intervensi manual.",
    highlight: "Skala 30x lebih cepat"
  },
  {
    icon: "⏱️",
    title: "Kerja sambil Tidur",
    desc: "Tinggal jadwalkan video, tutup laptop, tidur. Saat kamu bangun, ratusan video sudah tersebar di puluhan akun TikTok kamu.",
    highlight: "Autopilot 24/7"
  },
  {
    icon: "🛡️",
    title: "100% Anti Shadowban",
    desc: "Teknologi browser anti-fingerprint & RPA enterprise mensimulasikan perilaku manusia nyata. TikTok tidak bisa membedakannya.",
    highlight: "Aman & terpercaya"
  }
];
---
<section class="section features-section" aria-labelledby="features-heading">
  <div class="container text-center">
    <div class="section-badge" aria-label="Keunggulan utama software">KENAPA 2.000+ ORANG SUDAH PAKAI INI?</div>
    <h2 id="features-heading">Yang <span class="highlight">Tidak Pakai Ini</span> Akan<br/>Tertinggal Jauh Sekali</h2>
    <p class="subtitle text-muted">Ini bukan sekadar tools biasa. Ini adalah sistem otomatisasi TikTok paling lengkap yang pernah ada di Indonesia.</p>
    
    <div class="grid-4" role="list">
      {features.map((item) => (
        <div class="card feature-card" role="listitem">
          <div class="icon-circle" aria-hidden="true">{item.icon}</div>
          <h3>{item.title}</h3>
          <p class="text-muted">{item.desc}</p>
          <div class="feature-highlight" aria-label={`Manfaat: ${item.highlight}`}>
            <span aria-hidden="true">✅</span> {item.highlight}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--white);
    position: relative;
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    line-height: 1.25;
  }

  .subtitle {
    max-width: 600px;
    margin: 0 auto 50px;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: left;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    padding: 36px 28px;
    text-align: center;
    align-items: center;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    gap: 0;
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #eef2ff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
    box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.1);
    flex-shrink: 0;
  }

  h3 {
    font-size: 1.2rem;
    margin-bottom: 12px;
  }

  .feature-card p {
    font-size: 0.93rem;
    line-height: 1.65;
    flex: 1;
  }

  .feature-highlight {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    color: #065f46;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 30px;
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
    h2 { font-size: 2rem; }
  }
</style>
