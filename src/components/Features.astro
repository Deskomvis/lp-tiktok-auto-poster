---
// Features.astro
const features = [
  {
    icon: "🛒",
    title: "Auto Keranjang Kuning",
    desc: "Setiap video yang diupload langsung tertautkan produk TikTok Shop kamu secara otomatis. Tidak perlu lagi pilih satu per satu.",
    highlight: "Hemat 3–5 jam/hari"
  },
  {
    icon: "🤖",
    title: "Upload 30 Akun Sekaligus",
    desc: "Kelola puluhan akun TikTok dari satu dashboard. Software otomatis rotasi akun, upload, dan set deskripsi tanpa intervensi manual.",
    highlight: "Skala 30x lebih cepat"
  },
  {
    icon: "⏱️",
    title: "Kerja sambil Tidur",
    desc: "Tinggal jadwalkan video, tutup laptop, tidur. Saat kamu bangun, ratusan video sudah tersebar di puluhan akun TikTok kamu.",
    highlight: "Autopilot 24/7"
  },
  {
    icon: "🛡️",
    title: "100% Anti Shadowban",
    desc: "Teknologi browser anti-fingerprint & RPA enterprise mensimulasikan perilaku manusia nyata. TikTok tidak bisa membedakannya.",
    highlight: "Aman & terpercaya"
  }
];
---
<section class="section features-section" aria-labelledby="features-heading">
  <div class="container text-center">
    <div class="section-badge" aria-label="Keunggulan utama software">KENAPA 2.000+ ORANG SUDAH PAKAI INI?</div>
    <h2 id="features-heading">Yang <span class="highlight">Tidak Pakai Ini</span> Akan<br/>Tertinggal Jauh Sekali</h2>
    <p class="subtitle text-muted">Ini bukan sekadar tools biasa. Ini adalah sistem otomatisasi TikTok paling lengkap yang pernah ada di Indonesia.</p>
    
    <div class="grid-4" role="list">
      {features.map((item) => (
        <div class="card feature-card" role="listitem">
          <div class="icon-circle" aria-hidden="true">{item.icon}</div>
          <div class="feature-content">
            <h3>{item.title}</h3>
            <p class="text-muted">{item.desc}</p>
            <div class="feature-highlight" aria-label={`Manfaat: ${item.highlight}`}>
              <span aria-hidden="true">✅</span> {item.highlight}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--white);
    position: relative;
    padding: 100px 0;
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.08);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: 1px;
    border: 1px solid rgba(79, 70, 229, 0.1);
  }

  h2 {
    font-size: 2.8rem;
    margin-bottom: 24px;
    line-height: 1.2;
    color: var(--dark-violet);
  }

  .subtitle {
    max-width: 650px;
    margin: 0 auto 60px;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .highlight {
    color: var(--primary);
    position: relative;
    display: inline-block;
  }
  
  .highlight::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 8px;
    background: rgba(67, 56, 202, 0.1);
    z-index: -1;
    border-radius: 4px;
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    text-align: left;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    padding: 40px 30px;
    text-align: left;
    align-items: flex-start;
    background: var(--white);
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all 0.3s ease;
    height: 100%;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    border-color: rgba(79, 70, 229, 0.2);
  }

  .icon-circle {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 24px;
    transition: all 0.3s ease;
  }

  .feature-card:hover .icon-circle {
    background: var(--primary);
    color: white;
    transform: rotate(-5deg);
  }

  .feature-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h3 {
    font-size: 1.3rem;
    margin-bottom: 12px;
    color: var(--dark-violet);
    font-weight: 700;
  }

  .feature-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .feature-highlight {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    color: #059669;
    background: #ecfdf5;
    padding: 6px 14px;
    border-radius: 8px;
    border: 1px solid #d1fae5;
  }

  @media (max-width: 1200px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .features-section { padding: 60px 0; }
    h2 { font-size: 2.2rem; }
    .grid-4 { grid-template-columns: 1fr; gap: 20px; }
    
    .feature-card { 
      padding: 30px 24px; 
      flex-direction: column; 
      align-items: flex-start;
      gap: 0;
    }
    
    .icon-circle { 
      margin-bottom: 16px; 
      width: 48px; 
      height: 48px; 
      font-size: 20px; 
    }
    
    h3 { font-size: 1.2rem; margin-bottom: 8px; }
    .feature-card p { font-size: 0.9rem; margin-bottom: 16px; line-height: 1.5; }
    .feature-highlight { font-size: 0.8rem; }
    .subtitle { margin-bottom: 40px; }
  }
</style>

