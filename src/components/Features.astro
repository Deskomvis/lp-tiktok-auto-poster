---
// Features.astro
const features = [
  {
    icon: "🛒",
    title: "Auto Keranjang Kuning",
    desc: "Otomatis menautkan produk / keranjang kuning di setiap video tanpa harus pilih manual satu per satu."
  },
  {
    icon: "🤖",
    title: "Upload Puluhan Akun",
    desc: "Multi-akun bukan masalah. Software otomatis mengeksekusi upload ke berbagai profil berbeda secara bergantian."
  },
  {
    icon: "⏱️",
    title: "Kerja Terasa Ringan",
    desc: "Buang cara lama yang memakan waktu berjam-jam. Cukup siapkan bahan, klik mulai, dan biarkan software bekerja."
  },
  {
    icon: "🛡️",
    title: "Aman dari Shadowban",
    desc: "Menggunakan metode browser anti-detect sehingga perilaku sistem tetap aman dan tidak terdeteksi sebagai spammer."
  }
];
---
<section class="section features-section">
  <div class="container text-center">
    <div class="section-badge">KENAPA BUTUH TOOLS INI?</div>
    <h2>Yang TIDAK Pakai Ini Akan <span class="text-primary highlight">Tertinggal</span></h2>
    <p class="subtitle text-muted">Rahasia raksasa kreator & affiliator memiliki puluhan akun tanpa harus merekrut banyak admin upload khusus.</p>
    
    <div class="grid-4">
      {features.map((item) => (
        <div class="card feature-card">
          <div class="icon-circle" aria-hidden="true">{item.icon}</div>
          <h3>{item.title}</h3>
          <p class="text-muted">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background-color: var(--white);
    position: relative;
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .subtitle {
    max-width: 600px;
    margin: 0 auto 50px;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    text-align: left;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    padding: 40px 30px;
    text-align: center;
    align-items: center;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #eef2ff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
    box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.1);
  }

  h3 {
    font-size: 1.3rem;
    margin-bottom: 12px;
  }

  .feature-card p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
    h2 { font-size: 2rem; }
  }
</style>
