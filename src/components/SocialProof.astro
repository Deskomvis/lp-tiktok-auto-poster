---
// SocialProof.astro
const stats = [
  { num: "2.000+", label: "Pengguna Aktif" },
  { num: "30+", label: "Akun TikTok Sekaligus" },
  { num: "10 Menit", label: "Waktu Setup Awal" },
  { num: "24/7", label: "Bekerja Tanpa Istirahat" },
];

const roles = [
  "Ternak Akun TikTok",
  "Affiliator TikTok Shop",
  "Kreator Konten",
  "Brand Owner",
  "Agency Social Media",
  "Dropshipper",
];
---

<section class="social-proof-section" aria-labelledby="sp-heading">
  <div class="container">
    <!-- Stats Row -->
    <div class="stats-row" role="list" aria-label="Statistik pengguna software">
      {stats.map(s => (
        <div class="stat-box" role="listitem">
          <div class="stat-num">{s.num}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <hr class="sp-divider" aria-hidden="true" />

    <!-- Role Badges -->
    <p id="sp-heading" class="sp-title">Dipercaya oleh para:</p>
    <div class="roles-wrapper" role="list" aria-label="Tipe pengguna yang cocok">
      {roles.map(role => (
        <div class="role-badge" role="listitem">
          <span aria-hidden="true">✅</span> {role}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .social-proof-section {
    padding: 50px 0 60px;
    background: transparent;
    margin-top: -10px;
    position: relative;
    z-index: 10;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 40px;
    text-align: center;
  }

  .stat-box {
    background: var(--white);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    padding: 24px 16px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s;
  }

  .stat-box:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .stat-num {
    font-size: 1.9rem;
    font-weight: 900;
    color: var(--dark-violet);
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .sp-divider {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 0 0 30px;
  }

  .sp-title {
    font-size: 1rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 18px;
    text-align: center;
    letter-spacing: 0.3px;
  }

  .roles-wrapper {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .role-badge {
    background: var(--white);
    border: 1px solid rgba(0, 0, 0, 0.05);
    padding: 10px 20px;
    border-radius: 50px;
    font-weight: 600;
    color: var(--dark-violet);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .role-badge:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: rgba(79, 70, 229, 0.2);
  }

  @media (max-width: 768px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .role-badge { padding: 8px 16px; font-size: 0.88rem; }
  }

  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr 1fr; gap: 12px; }
  }
</style>
