---
// Comparison.astro
const manual = [
  "Login-logout pindah akun secara manual.",
  "Upload dan ketik konten satu-persatu per video.",
  "Waktu habis buat cari & tautkan keranjang kuning produk.",
  "Risiko gampang kena shadowban karena ketahuan spamming."
];

const auto = [
  "Rotasi dan upload puluhan akun dalam hitungan menit.",
  "Otomatis mengekstrak detail dari folder direktori.",
  "Pintar menautkan link keranjang kuning secara instan.",
  "Super aman menggunakan browser teknologi anti-detecting."
];
---
<section class="section comparison-section">
  <div class="container text-center">
    <h2>Cara Manual vs TikTok <span class="highlight">Auto Post</span></h2>
    <p class="subtitle text-muted">Pilihan cerdas kreator masa depan.</p>
    
    <div class="comparison-grid">
      <div class="comp-box manual">
        <div class="box-header">
          <h3>❌ CARA MANUAL</h3>
        </div>
        <ul class="comp-list">
          {manual.map(text => (
            <li>
              <span class="icon">😭</span>
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="comp-box auto">
        <div class="badge-best">PILIHAN TEPAT</div>
        <div class="box-header">
          <h3>✅ AUTO POST</h3>
        </div>
        <ul class="comp-list">
          {auto.map(text => (
            <li>
              <span class="icon">🔥</span>
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .comparison-section {
    background-color: #f8fafc;
    padding: 80px 0;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .subtitle { margin-bottom: 50px; font-size: 1.1rem; }
  
  .highlight {
    color: var(--primary);
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    max-width: 900px;
    margin: 0 auto;
  }

  .comp-box {
    background: var(--white);
    border-radius: var(--card-radius);
    overflow: hidden;
    position: relative;
    box-shadow: var(--shadow-md);
  }

  .box-header {
    padding: 20px;
    background: #f1f5f9;
    border-bottom: 1px solid #e2e8f0;
  }

  .box-header h3 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--text-main);
  }

  .comp-list {
    list-style: none;
    padding: 30px;
    text-align: left;
  }

  .comp-list li {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    align-items: flex-start;
  }

  .comp-list li:last-child {
    margin-bottom: 0;
  }

  .icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  /* Specifics for Auto */
  .comp-box.auto {
    border: 2px solid var(--primary);
    box-shadow: 0 20px 25px -5px rgba(79, 70, 229, 0.15);
    transform: scale(1.03);
    z-index: 10;
  }

  .comp-box.auto .box-header {
    background: rgba(79, 70, 229, 0.1);
    border-color: rgba(79, 70, 229, 0.2);
  }

  .comp-box.auto .box-header h3 {
    color: var(--primary);
  }

  .badge-best {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 6px 16px;
    border-bottom-left-radius: 12px;
  }

  @media (max-width: 768px) {
    .comparison-grid { grid-template-columns: 1fr; }
    .comp-box.auto { transform: none; margin-top: 20px; }
  }
</style>
