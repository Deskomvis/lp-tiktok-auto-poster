---
// CheckoutForm.astro
---
<section class="section checkout-section">
  <div class="container text-center">
    <h2>Setup 5 Menit — Hasilnya <span class="text-primary highlight">SEUMUR HIDUP</span></h2>
    <p class="subtitle text-muted">Investasi Terbaik Dalam Karir TikTok kamu. Jangan biarkan FYP-mu diambil kompetitor!</p>
    
    <div class="guarantee-badges">
      <div class="g-badge">✅ Akses Selamanya</div>
      <div class="g-badge">✅ Update Gratis</div>
      <div class="g-badge">✅ Panduan Lengkap</div>
      <div class="g-badge">✅ Support Group</div>
    </div>

    <div class="form-wrapper">
      <div class="form-card-glow" aria-hidden="true"></div>
      <div class="form-card">
        <div class="limited-banner">
          ⏰ HARGA PROMO TERBATAS — Bisa Naik Kapan Saja!
        </div>

        <div class="pricing-display">
          <p class="cheap-bait">Jauh lebih murah dibanding bayar admin sebulan!</p>
          <div class="prices">
            <span class="price-coret">Rp 799.000</span>
            <span class="price-now">Rp 499.000</span>
          </div>
        </div>

        <!-- CTA BUTTON (Replaced Iframe) -->
        <a href="https://prodig.deskomvis.com/checkout-tiktok-autopost" class="btn btn-danger btn-pulse-red" aria-label="Amankan harga promo software sebelum masa diskon berakhir">
          🛒 AMANKAN SEKARANG SEBELUM HARGA NAIK!
        </a>
        <!-- CTA BUTTON END -->
      </div>
    </div>

    <div class="risk-reversal">
      <p>🔒 Pembayaran aman & terenkripsi. Akses langsung setelah pembayaran dikonfirmasi.</p>
    </div>
  </div>
</section>

<style>
  .checkout-section {
    padding: 100px 0;
    background: linear-gradient(180deg, #f8fafc 0%, #eff6ff 100%);
    position: relative;
    overflow: hidden;
  }

  h2 {
    font-size: 2.8rem;
    margin-bottom: 20px;
  }

  .subtitle {
    max-width: 600px;
    margin: 0 auto 50px;
    font-size: 1.2rem;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .form-wrapper {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .form-card-glow {
    position: absolute;
    top: -20px;
    left: -20px;
    right: -20px;
    bottom: -20px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.4) 0%, rgba(139, 92, 246, 0.1) 100%);
    filter: blur(40px);
    z-index: 1;
    border-radius: 40px;
  }

  .form-card {
    position: relative;
    z-index: 2;
    background: var(--white);
    padding: 40px;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.5);
    text-align: center;
  }

  .btn-danger {
    background: linear-gradient(90deg, #dc2626 0%, #b91c1c 100%);
    color: white;
    padding: 20px 40px;
    font-size: 1.3rem;
    font-weight: 800;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    margin-top: 10px;
    transition: all 0.3s;
    box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.5);
  }

  .btn-danger:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -5px rgba(220, 38, 38, 0.6);
  }

  .btn-pulse-red {
    animation: pulseRed 2s infinite;
  }

  @keyframes pulseRed {
    0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(220, 38, 38, 0); }
    100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
  }

  .guarantee-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    margin-bottom: 40px;
  }

  .g-badge {
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    padding: 10px 20px;
    border-radius: 50px;
    font-weight: 700;
    color: #065f46;
    font-size: 0.95rem;
  }

  .pricing-display {
    margin: 20px 0 25px;
  }

  .cheap-bait {
    font-size: 0.95rem;
    color: #4b5563;
    font-weight: 600;
    margin-bottom: 8px;
    background: #f3f4f6;
    display: inline-block;
    padding: 6px 16px;
    border-radius: 50px;
  }

  .prices {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
  }

  .price-coret {
    font-size: 1.3rem;
    color: #9ca3af;
    text-decoration: line-through;
    font-weight: 600;
  }

  .price-now {
    font-size: 2.5rem;
    color: #059669;
    font-weight: 900;
    line-height: 1;
  }

  .limited-banner {
    background: linear-gradient(90deg, #fef3c7 0%, #fde68a 100%);
    border: 1px solid #f59e0b;
    color: #92400e;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    text-align: center;
    animation: bannerPulse 3s infinite;
  }

  @keyframes bannerPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }

  .risk-reversal {
    margin-top: 30px;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .risk-reversal p {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,0,0,0.03);
    padding: 10px 20px;
    border-radius: 50px;
  }

  @media (max-width: 768px) {
    h2 { font-size: 2.2rem; }
    .form-card { padding: 20px 10px; }
  }
</style>
