---
// CheckoutForm.astro
---
<section class="section checkout-section" aria-labelledby="checkout-heading">
  <div class="container text-center">
    <div class="section-badge" aria-hidden="true">INVESTASI SEKALI, HASILKAN SELAMANYA</div>
    <h2 id="checkout-heading">Setup 5 Menit — Hasilkan Komisi <span class="highlight">Tanpa Batas.</span></h2>
    <p class="subtitle text-muted">Bayangkan 3 bulan dari sekarang: kompetitor kamu makin jauh di depan, sementara kamu masih upload manual. Atau kamu yang sudah otomatis dari hari ini?</p>
    
    <!-- Value Stack -->
    <div class="value-stack" role="list" aria-label="Yang kamu dapatkan">
      <div class="value-item" role="listitem">
        <span class="vi-icon" aria-hidden="true">🎓</span>
        <div>
          <strong>E-Course Step-by-Step</strong>
          <span class="vi-sub">Dari nol hingga upload massal berjalan</span>
        </div>
      </div>
      <div class="value-item" role="listitem">
        <span class="vi-icon" aria-hidden="true">⚙️</span>
        <div>
          <strong>Software TikTok Auto Poster</strong>
          <span class="vi-sub">Windows & Mac · Update gratis selamanya</span>
        </div>
      </div>
      <div class="value-item" role="listitem">
        <span class="vi-icon" aria-hidden="true">👥</span>
        <div>
          <strong>Akses Grup Eksklusif</strong>
          <span class="vi-sub">Support komunitas & tips terbaru</span>
        </div>
      </div>
    </div>

    <div class="form-wrapper">
      <div class="form-card-glow" aria-hidden="true"></div>
      <div class="form-card">
        <div class="limited-banner" aria-label="Harga promo terbatas berlaku sekarang">
          <span aria-hidden="true">⏰</span> HARGA PROMO — Gunakan Kode <strong>DISKON25%</strong>
        </div>

        <div class="pricing-display">
          <p class="cheap-bait">
            Bandingkan: Bayar admin upload Rp 2–3 juta/bulan vs sekali bayar selamanya!
          </p>
          <div class="prices" aria-label="Perbandingan harga">
            <div class="price-group">
              <span class="price-label" aria-label="Harga normal">Harga Normal</span>
              <span class="price-coret" aria-label="Rp 499.000 dicoret">Rp 499.000</span>
            </div>
            <div class="price-arrow" aria-hidden="true">→</div>
            <div class="price-group">
              <span class="price-label price-label-now">Harga Kamu</span>
              <span class="price-now" aria-label="Rp 374.250">Rp 374.250</span>
            </div>
          </div>
          <div class="savings-badge" aria-label="Kamu hemat Rp 124.750">
            <span aria-hidden="true">🎉</span> Hemat Rp 124.750!
          </div>
        </div>

        <div class="coupon-note" aria-label="Instruksi penggunaan kode kupon">
          <span aria-hidden="true">🏷️</span>
          Masukkan kode kupon <span class="coupon-code">DISKON25%</span> saat checkout untuk mendapatkan harga ini
        </div>

        <!-- CTA BUTTON -->
        <a href="https://prodig.deskomvis.com/checkout-tiktok-autopost" class="btn btn-danger btn-pulse-red" aria-label="Amankan harga promo Rp 374.250 dengan kode DISKON25% sebelum berakhir">
          <span aria-hidden="true">🛒</span> AMANKAN HARGA RP 374.250 SEKARANG!
        </a>
        <!-- CTA BUTTON END -->

        <div class="guarantee-badges" role="list" aria-label="Garansi dan keuntungan pembelian">
          <div class="g-badge" role="listitem"><span aria-hidden="true">✅</span> Akses Selamanya</div>
          <div class="g-badge" role="listitem"><span aria-hidden="true">✅</span> Update Gratis</div>
          <div class="g-badge" role="listitem"><span aria-hidden="true">✅</span> Panduan Lengkap</div>
          <div class="g-badge" role="listitem"><span aria-hidden="true">✅</span> Support Grup</div>
        </div>
      </div>
    </div>

    <div class="risk-reversal" role="note">
      <p><span aria-hidden="true">🔒</span> Pembayaran aman & terenkripsi. Akses langsung dikirim setelah pembayaran dikonfirmasi.</p>
    </div>
  </div>
</section>

<style>
  .checkout-section {
    padding: 100px 0;
    background: linear-gradient(180deg, #f8fafc 0%, #eff6ff 100%);
    position: relative;
    overflow: hidden;
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  h2 {
    font-size: 2.6rem;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .subtitle {
    max-width: 620px;
    margin: 0 auto 40px;
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Value Stack */
  .value-stack {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: white;
    border: 1px solid rgba(0,0,0,0.06);
    padding: 16px 20px;
    border-radius: 14px;
    text-align: left;
    box-shadow: var(--shadow-sm);
    min-width: 220px;
    max-width: 280px;
  }

  .vi-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
  }

  .value-item strong {
    display: block;
    font-size: 0.93rem;
    color: var(--dark-violet);
    margin-bottom: 2px;
  }

  .vi-sub {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .form-wrapper {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .form-card-glow {
    position: absolute;
    top: -20px;
    left: -20px;
    right: -20px;
    bottom: -20px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.35) 0%, rgba(139, 92, 246, 0.1) 100%);
    filter: blur(40px);
    z-index: 1;
    border-radius: 40px;
  }

  .form-card {
    position: relative;
    z-index: 2;
    background: var(--white);
    padding: 44px 40px;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.5);
    text-align: center;
  }

  .btn-danger {
    background: linear-gradient(90deg, #dc2626 0%, #b91c1c 100%);
    color: white;
    padding: 20px 40px;
    font-size: 1.2rem;
    font-weight: 800;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    margin-top: 10px;
    transition: all 0.3s;
    box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.5);
    font-family: var(--font-family);
    text-decoration: none;
  }

  .btn-danger:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -5px rgba(220, 38, 38, 0.6);
  }

  .btn-pulse-red {
    animation: pulseRed 2s infinite;
  }

  @keyframes pulseRed {
    0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(220, 38, 38, 0); }
    100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
  }

  .guarantee-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 24px;
  }

  .g-badge {
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    padding: 8px 16px;
    border-radius: 50px;
    font-weight: 700;
    color: #065f46;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .pricing-display {
    margin: 20px 0 20px;
  }

  .cheap-bait {
    font-size: 0.92rem;
    color: #4b5563;
    font-weight: 600;
    margin-bottom: 18px;
    background: #f3f4f6;
    display: inline-block;
    padding: 8px 18px;
    border-radius: 50px;
    line-height: 1.5;
  }

  .prices {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .price-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .price-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .price-label-now {
    color: #16a34a;
  }

  .price-arrow {
    font-size: 1.5rem;
    color: #9ca3af;
    margin-top: 16px;
  }

  .price-coret {
    font-size: 1.4rem;
    color: #9ca3af;
    text-decoration: line-through;
    font-weight: 600;
  }

  .price-now {
    font-size: 2.8rem;
    color: #16a34a;
    font-weight: 900;
    line-height: 1;
  }

  .savings-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #fef9c3;
    border: 1px solid #fde047;
    color: #713f12;
    font-weight: 800;
    font-size: 0.9rem;
    padding: 6px 16px;
    border-radius: 30px;
    margin-top: 6px;
  }

  .coupon-note {
    background: #f0f9ff;
    border: 1px dashed #0ea5e9;
    color: #0369a1;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 20px;
    border-radius: 10px;
    margin: 16px 0 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    line-height: 1.5;
  }

  .coupon-code {
    background: #e0f2fe;
    border: 1px solid #0ea5e9;
    padding: 2px 10px;
    border-radius: 6px;
    font-family: monospace;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    color: #0369a1;
  }

  .limited-banner {
    background: linear-gradient(90deg, #fef3c7 0%, #fde68a 100%);
    border: 1px solid #f59e0b;
    color: #78350f;
    font-weight: 800;
    font-size: 1rem;
    padding: 14px 20px;
    border-radius: 12px;
    margin-bottom: 24px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    animation: bannerPulse 3s infinite;
  }

  @keyframes bannerPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }

  .risk-reversal {
    margin-top: 28px;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .risk-reversal p {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,0,0,0.03);
    padding: 10px 20px;
    border-radius: 50px;
  }

  @media (max-width: 768px) {
    .checkout-section { padding: 56px 0 72px; }
    h2 { font-size: 1.8rem; }
    .subtitle { font-size: 0.95rem; margin-bottom: 28px; }
    .value-stack { flex-direction: column; gap: 12px; }
    .value-item { min-width: unset; max-width: 100%; width: 100%; }
    .vi-icon { font-size: 1.5rem; }
    .value-item strong { font-size: 0.88rem; }
    .form-card { padding: 24px 16px; }
    .limited-banner { font-size: 0.88rem; padding: 12px 14px; }
    .price-arrow { display: none; }
    .prices { gap: 12px; }
    .price-coret { font-size: 1.15rem; }
    .price-now { font-size: 2.2rem; }
    .cheap-bait { font-size: 0.85rem; padding: 6px 14px; }
    .coupon-note { font-size: 0.83rem; padding: 10px 14px; }
    .coupon-code { font-size: 0.9rem; }
    .btn-danger { font-size: 1rem; padding: 16px 20px; border-radius: 14px; }
    .guarantee-badges { gap: 8px; }
    .g-badge { font-size: 0.78rem; padding: 7px 12px; }
    .risk-reversal { font-size: 0.8rem; }
    .risk-reversal p { padding: 8px 16px; }
  }
</style>
