---
// Hero.astro
import { Image } from 'astro:assets';
---
<section class="hero-section">
  <div class="container hero-container">
    <div class="hero-content">
      <div class="badge" aria-label="E-Course dan Software Upload TikTok Massal">
        <span aria-hidden="true">🚀</span> AUTOMATION EXPERT · TERPERCAYA
      </div>
      <h1>
        Upload ke <span class="text-highlight">30 Akun TikTok</span><br/>
        Dalam 5 Menit —<br/>
        <span class="text-primary italic-text">Lakukan Sambil Tidur.</span>
      </h1>
      <p class="hero-desc">
        Hentikan cara lama upload <strong>satu per satu</strong>. Gunakan sistem otomasi cerdas untuk
        distribusi video ke puluhan akun, auto-tautkan <strong>Keranjang Kuning</strong>, dan raih komisi secara autopilot.
      </p>
      
      <div class="trust-row" aria-label="Bukti kepercayaan pengguna">
        <div class="trust-item">
          <span class="trust-num" aria-hidden="true">2.000+</span>
          <span class="trust-label">Active Users</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-num" aria-hidden="true">30+</span>
          <span class="trust-label">Accounts Per Click</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-num" aria-hidden="true">5m</span>
          <span class="trust-label">Fast Setup</span>
        </div>
      </div>

      <div class="cta-wrapper">
        <a href="https://prodig.deskomvis.com/checkout-tiktok-autopost" class="btn btn-primary btn-pulse" aria-label="Akses software upload TikTok otomatis sekarang dengan harga promo">
          SAYA MAU OTOMATIS SEKARANG!
        </a>
        <p class="cta-note"><span aria-hidden="true">🔒</span> One-time payment · Lifetime Access · Promo segera berakhir</p>
        <div class="live-counter" aria-hidden="true">
          <span class="live-dot"></span>
          <span id="live-viewers"></span> orang sedang melihat peluang ini
        </div>
      </div>
      <script is:inline>
        const el = document.getElementById('live-viewers');
        if(el) el.textContent = Math.floor(Math.random() * 15) + 18;
        setInterval(() => { if(el) el.textContent = Math.floor(Math.random() * 15) + 18; }, 8000);
      </script>
    </div>
    <div class="hero-image">
      <div class="hero-badge-float" aria-hidden="true">
        <span class="hbf-dot"></span> System Running...
      </div>
      <Image 
        src="https://tiktok-autopost.lovable.app/assets/dashboard-Bf38sSxt.webp" 
        alt="Dashboard TikTok Auto Poster menampilkan multi-akun upload berjalan otomatis" 
        class="hero-mockup-img float-anim" 
        inferSize
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
  
  <div class="scroll-indicator" aria-hidden="true">
    <div class="mouse"></div>
    <span>Pelajari Lebih Lanjut</span>
  </div>
</section>

<style>
  .hero-section {
    padding: 120px 0 80px;
    background: #ffffff;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    width: 80%;
    height: 100%;
    background: radial-gradient(circle at 0% 0%, rgba(67, 56, 202, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 100% 100%, rgba(99, 102, 241, 0.02) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: #f1f5f9;
    color: var(--primary);
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.75rem;
    margin-bottom: 32px;
    letter-spacing: 0.5px;
    border: 1px solid #e2e8f0;
  }

  h1 {
    font-size: 3.8rem;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
    line-height: 1.1;
    color: var(--dark-violet);
  }

  .text-highlight {
    color: var(--primary);
    position: relative;
  }

  .italic-text {
    font-style: italic;
    opacity: 0.8;
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    max-width: 540px;
    line-height: 1.7;
  }

  /* Trust Row */
  .trust-row {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-bottom: 48px;
    padding: 20px 0;
    border-top: 1px solid #f1f5f9;
    border-bottom: 1px solid #f1f5f9;
    width: fit-content;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .trust-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--dark-violet);
    line-height: 1;
  }

  .trust-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 600;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .trust-divider {
    width: 1px;
    height: 32px;
    background: #e2e8f0;
  }

  /* CTA */
  .cta-note {
    margin-top: 16px;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .live-counter {
    margin-top: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: blink-dot 1.2s infinite;
    flex-shrink: 0;
  }

  @keyframes blink-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
    50% { opacity: 0.5; box-shadow: 0 0 0 4px rgba(16, 185, 129, 0); }
  }

  /* Mockup */
  .hero-image {
    position: relative;
  }

  .hero-badge-float {
    position: absolute;
    top: 10%;
    left: -20px;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px 20px;
    font-size: 0.85rem;
    font-weight: 700;
    color: #10b981;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    z-index: 5;
    animation: float-badge 4s ease-in-out infinite;
  }

  .hbf-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: blink-dot 1s infinite;
  }

  @keyframes float-badge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .hero-mockup-img {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.12));
    border-radius: 20px;
  }

  .float-anim {
    animation: float 8s ease-in-out infinite;
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
  }

  .mouse {
    width: 20px;
    height: 32px;
    border: 2px solid var(--text-muted);
    border-radius: 12px;
    position: relative;
  }

  .mouse::after {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    width: 2px;
    height: 6px;
    background: var(--text-muted);
    transform: translateX(-50%);
    border-radius: 2px;
    animation: scroll-mouse 2s infinite;
  }

  @keyframes scroll-mouse {
    0% { transform: translate(-50%, 0); opacity: 1; }
    100% { transform: translate(-50%, 15px); opacity: 0; }
  }

  @media (max-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
    }
    h1 { font-size: 3rem; }
    .hero-desc { margin: 0 auto 40px; }
    .trust-row { margin: 0 auto 48px; }
    .cta-note, .live-counter { justify-content: center; }
    .hero-badge-float { left: 50%; transform: translateX(-50%); top: -40px; }
  }

  @media (max-width: 768px) {
    .hero-section { padding: 100px 0 60px; }
    h1 { font-size: clamp(2.2rem, 9vw, 3rem); }
    .trust-row { gap: 20px; }
    .trust-num { font-size: 1.3rem; }
    .scroll-indicator { display: none; }
  }

  @media (max-width: 480px) {
    .hero-section { padding: 80px 0 50px; }
    h1 { font-size: 2rem; }
  }
</style>

</style>
