---
// HowItWorks.astro
const steps = [
  {
    emoji: "📁",
    title: "Siapkan Video & Detail Produk",
    desc: "Kumpulkan semua video, caption, dan ID link produk TikTok Shop ke dalam satu folder. Tidak perlu skill teknis — guru SD pun bisa."
  },
  {
    emoji: "⚡",
    title: "Klik Start — Biarkan Software Bekerja",
    desc: "Buka software, pilih akun-akun TikTok kamu, lalu tekan Start. Software langsung login otomatis, upload, tambah deskripsi, tautkan keranjang kuning — semua dalam sekali klik."
  },
  {
    emoji: "💰",
    title: "Komisi Masuk, Kamu Santai",
    desc: "Sambil kamu makan, tidur, atau fokus ke hal lain — software kamu terus bekerja menyebarkan konten ke semua akun. Trafik mengalir, komisi terus masuk."
  }
];
---
<section class="section how-it-works" aria-labelledby="hiw-heading">
  <div class="container text-center">
    <div class="section-badge" aria-hidden="true">MUDAH & PRAKTIS</div>
    <h2 id="hiw-heading">Begini Cara Kerjanya —<br/><span class="text-primary highlight">Cuma 3 Langkah</span></h2>
    <p class="subtitle text-muted">Tidak butuh coding. Tidak butuh keahlian teknis. Hanya butuh <strong>5 menit setup awal</strong>, setelah itu biarkan software yang bekerja.</p>
    
    <div class="steps-container" role="list" aria-label="Langkah penggunaan software">
      {steps.map((step, index) => (
        <div class="step-card" role="listitem">
          <div class="step-number" aria-label={`Langkah ${index + 1}`}>{index + 1}</div>
          <div class="step-emoji" aria-hidden="true">{step.emoji}</div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p class="text-muted">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="hiw-cta">
      <a href="https://prodig.deskomvis.com/checkout-tiktok-autopost" class="btn btn-primary" aria-label="Mulai otomatisasi TikTok sekarang">
        <span aria-hidden="true">🚀</span> Mulai Otomatisasi Sekarang
      </a>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: linear-gradient(180deg, var(--bg-color) 0%, rgba(99, 102, 241, 0.05) 50%, #ffffff 100%);
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.25;
  }

  .subtitle {
    max-width: 600px;
    margin: 0 auto 60px;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .steps-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 820px;
    margin: 0 auto;
  }

  .step-card {
    background: var(--white);
    padding: 36px 40px;
    border-radius: var(--card-radius);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: flex-start;
    gap: 28px;
    text-align: left;
    position: relative;
    border: 1px solid rgba(0,0,0,0.04);
    transition: transform 0.3s;
  }

  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 30px -10px rgba(79, 70, 229, 0.12);
  }

  .step-number {
    position: absolute;
    top: -18px;
    left: 36px;
    width: 44px;
    height: 44px;
    background: var(--primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    font-weight: 900;
    border-radius: 50%;
    box-shadow: 0 8px 16px -3px rgba(67, 56, 202, 0.4);
    border: 4px solid var(--white);
    flex-shrink: 0;
  }

  .step-emoji {
    font-size: 2.2rem;
    margin-top: 8px;
    flex-shrink: 0;
  }

  .step-content {
    flex: 1;
    margin-top: 6px;
  }

  .step-card h3 {
    font-size: 1.35rem;
    margin-bottom: 10px;
    color: var(--dark-violet);
  }

  .step-card p {
    font-size: 1rem;
    line-height: 1.7;
  }

  .hiw-cta {
    margin-top: 50px;
  }

  @media (max-width: 768px) {
    h2 { font-size: 1.8rem; }
    .subtitle { font-size: 0.95rem; margin-bottom: 40px; }
    .step-card { 
      padding: 26px 16px 22px 20px; 
      gap: 14px;
    }
    .step-number { top: -16px; left: 16px; width: 36px; height: 36px; font-size: 1.1rem; border-width: 3px; }
    .step-emoji { font-size: 1.8rem; margin-top: 4px; }
    .step-card h3 { font-size: 1.05rem; margin-bottom: 6px; }
    .step-card p { font-size: 0.92rem; }
    .hiw-cta { margin-top: 36px; }
  }

  @media (max-width: 480px) {
    .step-card { flex-direction: column; gap: 8px; padding: 28px 16px 20px; }
    .step-emoji { margin-top: 0; font-size: 1.5rem; }
  }
</style>
