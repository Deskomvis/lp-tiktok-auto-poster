---
// CourseModules.astro
const modules = [
  {
    num: "1",
    title: "Persiapan & Instalasi Sistem",
    subtitle: "Mulai dari Nol, Jalan Sepenuhnya",
    lessons: [
      "Intro & gambaran sistem lengkap",
      "Download & install browser anti-fingerprint",
      "Setup pertama kali yang benar (anti error)"
    ]
  },
  {
    num: "2",
    title: "Keamanan Akun TikTok",
    subtitle: "Anti-Detect Browser & Teknik Proxy",
    lessons: [
      "Cara beli proxy yang aman & murah",
      "Konfigurasi anti-detect browser step-by-step",
      "Tambahkan & kelola puluhan profile sekaligus",
      "Login akun TikTok ke tiap profile tanpa terdeteksi"
    ]
  },
  {
    num: "3",
    title: "Konfigurasi Software Otomasi",
    subtitle: "Hubungkan Semuanya dalam 1 Klik",
    lessons: [
      "Menghubungkan browser ke TikTok AutoPoster",
      "Export & import profile antar device",
      "Setting keranjang kuning & auto-link produk"
    ]
  },
  {
    num: "4",
    title: "Eksekusi Upload Massal",
    subtitle: "Dari 1 Video ke 30 Akun Sekaligus",
    lessons: [
      "Panduan lengkap dashboard software",
      "Konfigurasi bulk upload & jadwal otomatis",
      "Tekan Start — biarkan software bekerja sendiri",
      "Monitoring hasil & troubleshooting umum"
    ]
  }
];
---

<section class="section modules-section" aria-labelledby="modules-heading">
  <div class="container text-center">
    <div class="section-badge" aria-hidden="true">ISI MATERI LENGKAP</div>
    <h2 id="modules-heading">Apa yang Akan Kamu <span class="text-primary highlight">Kuasai Setelah Beli?</span></h2>
    <p class="subtitle text-muted">Tutorial step-by-step dari nol hingga mahir. Dari yang belum pernah pakai software otomasi sekalipun, bisa langsung jalan dalam 1 hari.</p>
    
    <div class="modules-grid" role="list" aria-label="Daftar modul e-course">
      {modules.map((mod) => (
        <div class="module-card" role="listitem">
          <div class="mod-header">
            <div class="mod-num" aria-label={`Modul ${mod.num}`}>MODUL {mod.num}</div>
            <h3 class="mod-title">{mod.title}</h3>
            {mod.subtitle && <p class="mod-subtitle">{mod.subtitle}</p>}
          </div>
          <div class="mod-body">
            <ul class="lesson-list" aria-label={`Pelajaran dalam modul ${mod.num}`}>
              {mod.lessons.map(lesson => (
                <li>
                  <span class="check-icon" aria-hidden="true">▶</span>
                  {lesson}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="bonus-bar" role="note" aria-label="Bonus tambahan yang didapat">
      <span aria-hidden="true">🎁</span>
      <strong>BONUS:</strong> Akses grup eksklusif untuk update terbaru, Q&A langsung dengan mentor, dan tips rahasia tambahan dari komunitas.
    </div>
  </div>
</section>

<style>
  .modules-section {
    background-color: #f8fafc;
    position: relative;
    padding: 80px 0;
  }

  .section-badge {
    display: inline-block;
    color: var(--primary);
    background: rgba(79, 70, 229, 0.1);
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    line-height: 1.25;
  }

  .subtitle {
    max-width: 600px;
    margin: 0 auto 50px;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary) 0%, #a855f7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 1000px;
    margin: 0 auto;
    text-align: left;
  }

  .module-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0,0,0,0.05);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .module-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 30px -10px rgba(79, 70, 229, 0.12);
  }

  .mod-header {
    background: linear-gradient(135deg, var(--dark-violet) 0%, #312e81 100%);
    color: white;
    padding: 28px 24px;
  }

  .mod-num {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #a5b4fc;
    margin-bottom: 8px;
  }

  .mod-title {
    color: white;
    font-size: 1.3rem;
    margin: 0;
    line-height: 1.3;
  }

  .mod-subtitle {
    margin-top: 6px;
    font-size: 0.88rem;
    color: #c7d2fe;
    opacity: 0.9;
  }

  .mod-body {
    padding: 24px;
    flex-grow: 1;
  }

  .lesson-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .lesson-list li {
    padding: 11px 0;
    border-bottom: 1px dashed #e2e8f0;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.93rem;
    color: var(--text-main);
    line-height: 1.55;
  }

  .lesson-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .lesson-list li:first-child {
    padding-top: 0;
  }

  .check-icon {
    color: var(--primary);
    font-size: 0.75rem;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .bonus-bar {
    margin: 40px auto 0;
    max-width: 800px;
    background: linear-gradient(90deg, rgba(79, 70, 229, 0.07) 0%, rgba(139, 92, 246, 0.07) 100%);
    border: 1px solid rgba(79, 70, 229, 0.2);
    padding: 20px 28px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 0.97rem;
    color: var(--dark-violet);
    text-align: center;
    flex-wrap: wrap;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .modules-section { padding: 48px 0; }
    .modules-grid { grid-template-columns: 1fr; gap: 16px; }
    h2 { font-size: 1.8rem; }
    .subtitle { font-size: 0.95rem; margin-bottom: 32px; }
    .mod-header { padding: 22px 20px; }
    .mod-title { font-size: 1.15rem; }
    .mod-body { padding: 18px 18px; }
    .lesson-list li { font-size: 0.88rem; gap: 10px; padding: 9px 0; }
    .bonus-bar { font-size: 0.88rem; padding: 16px 16px; margin-top: 28px; }
  }
</style>
